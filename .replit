modules = ["rust-stable"]
[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Build Octopus (Rust)"

[[workflows.workflow]]
name = "Build Octopus (Rust)"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cargo build --release 2>&1 && echo '' && echo '=== Build complete ===' && echo '' && ./target/release/octopus --help"

[workflows.workflow.metadata]
outputType = "console"
